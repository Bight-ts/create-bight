{
  "name": "create-bight",
  "version": "0.2.0",
  "type": "module",
  "description": "Create command for the Bight.ts Discord bot framework",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bight-ts/create-bight",
    "directory": "packages/create-bight"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-bight": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "pnpm run test && pnpm run build",
    "smoke:published": "pnpm run build && node ../../scripts/smoke-cli.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
